{
  "instance_display_name": "laboratory",
  "shape": "VM.Standard.A1.Flex",
  "ocpus": 4,
  "memory_in_gbs": 24,
  "operating_system": "Canonical Ubuntu",
  "operating_system_version": "24.04",
  "try_a2_conversion": true,
  "a2_conversion_ocpus": 1,
  "a2_conversion_memory_in_gbs": 6,
  "a2_max_launch_attempts": 2,
  "a2_conversion_retries": 3,
  "retry_delay_seconds": 90,
  "oci_timeout_seconds": 120,
  "oci_heartbeat_seconds": 15,
  "open_console_on_success": {
    "env": "OCI_OPEN_CONSOLE_ON_SUCCESS",
    "default": true
  },
  "assign_public_ip": true,
  "oci_auth": {
    "env": "OCI_AUTH_MODE",
    "default": "api_key"
  },
  "compartment_id": {
    "env": "OCI_COMPARTMENT_ID"
  },
  "subnet_id": {
    "env": "OCI_SUBNET_ID"
  },
  "ssh_public_key_path": {
    "env": "OCI_SSH_PUBLIC_KEY_PATH"
  },
  "availability_domain": {
    "env": "OCI_AVAILABILITY_DOMAIN",
    "default": ""
  },
  "cloud_init_template": "fleet/laboratory/cloud-init.sh"
}
